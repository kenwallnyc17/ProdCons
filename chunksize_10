MapNode* rotate_right(MapNode* y) noexcept {
        MapNode* x = y->left;
        MapNode* T2 = x->right;
        MapNode* p = y->parent; // Capture original parent immediately

        x->right = y;
        y->left = T2;

        // Establish upward parent link assignments cleanly
        x->parent = p;
        y->parent = x;
        if (T2) T2->parent = y;

        // CRITICAL FIX: Notify the original parent about its brand-new sub-root child
        if (p != nullptr) {
            if (p->left == y) p->left = x;
            else p->right = x;
        }

        update_height(y);
        update_height(x);
        return x;
    }

    MapNode* rotate_left(MapNode* x) noexcept {
        MapNode* y = x->right;
        MapNode* T2 = y->left;
        MapNode* p = x->parent; // Capture original parent immediately

        y->left = x;
        x->right = T2;

        // Establish upward parent link assignments cleanly
        y->parent = p;
        x->parent = y;
        if (T2) T2->parent = x;

        // CRITICAL FIX: Notify the original parent about its brand-new sub-root child
        if (p != nullptr) {
            if (p->left == x) p->left = y;
            else p->right = y;
        }

        update_height(x);
        update_height(y);
        return y;
    }

    // Streamlined upward rebalancing phase
    void balance_upward(MapNode* node) noexcept {
        while (node != nullptr) {
            update_height(node);
            int32_t balance = get_balance(node);

            MapNode* new_sub_root = node;
            if (balance > 1) {
                if (get_balance(node->left) < 0) {
                    node->left = rotate_left(node->left);
                }
                new_sub_root = rotate_right(node);
            } else if (balance < -1) {
                if (get_balance(node->right) > 0) {
                    node->right = rotate_right(node->right);
                }
                new_sub_root = rotate_left(node);
            }

            if (new_sub_root->parent == nullptr) {
                root_ = new_sub_root; // Capture top-level tree root updates smoothly
            }
            node = new_sub_root->parent; // Step straight up to parent register context
        }
    }






// Size: Exactly 128 bytes (Spans 2 L1 Cache Lines perfectly). Fully aligned.
struct alignas(64) MapNode {
    uint64_t         key;        // 8 bytes
    PrcLevelGeneric  value;      // 40 bytes
    MapNode*         left;       // 8 bytes
    MapNode*         right;      // 8 bytes
    MapNode*         parent;     // 8 bytes
    int32_t          height;     // 4 bytes
    uint8_t          padding[4]; // Padding to secure exact 128-byte cache boundaries
};

template <size_t PreallocCapacity>
class HybridNodePool {
private:
    alignas(64) std::array<uint8_t, PreallocCapacity * sizeof(MapNode)> arena_;
    MapNode* free_head_{nullptr};
    size_t   prealloc_used_{0};

public:
    HybridNodePool() noexcept {
        MapNode* base = reinterpret_cast<MapNode*>(arena_.data());
        for (size_t i = 0; i < PreallocCapacity - 1; ++i) {
            base[i].left = &base[i + 1];
        }
        base[PreallocCapacity - 1].left = nullptr;
        free_head_ = base;
    }

    [[nodiscard]] [[gnu::always_inline]] inline MapNode* allocate() noexcept {
        if (free_head_) [[likely]] {
            MapNode* node = free_head_;
            free_head_ = free_head_->left;
            ++prealloc_used_;
            return node;
        }
        void* raw_mem = std::aligned_alloc(64, sizeof(MapNode));
        if (!raw_mem) [[unlikely]] return nullptr;
        return static_cast<MapNode*>(raw_mem);
    }

    [[gnu::always_inline]] inline void deallocate(MapNode* node) noexcept {
        if (!node) [[unlikely]] return;
        
        uint8_t* ptr_bytes = reinterpret_cast<uint8_t*>(node);
        if (ptr_bytes >= arena_.data() && ptr_bytes < arena_.data() + arena_.size()) [[likely]] {
            node->left = free_head_;
            free_head_ = node;
            --prealloc_used_;
        } else {
            std::free(node); 
        }
    }

    [[nodiscard]] inline size_t pool_usage() const noexcept { return prealloc_used_; }
};


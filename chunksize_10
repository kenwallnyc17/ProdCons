    using iterator       = MapIterator<PreallocCapacity, Compare>;
    using const_iterator = MapIterator<PreallocCapacity, Compare>;

    [[nodiscard]] inline iterator begin() noexcept { return iterator(this, first()); }
    [[nodiscard]] inline iterator end() noexcept   { return iterator(this, nullptr); }
    [[nodiscard]] inline const_iterator begin() const noexcept { return const_iterator(this, const_cast<FastNodeMap*>(this)->first()); }
    [[nodiscard]] inline const_iterator end() const noexcept   { return const_iterator(this, nullptr); }

    [[nodiscard]] [[gnu::always_inline]] inline size_t size() const noexcept { return size_; }
    [[nodiscard]] [[gnu::always_inline]] inline bool empty() const noexcept { return size_ == 0; }
    [[nodiscard]] inline size_t prealloc_pool_usage() const noexcept { return pool_.pool_usage(); }

    template <typename... Args>
    [[gnu::always_inline]] inline std::pair<MapNode*, bool> try_emplace(uint64_t key, Args&&... args) noexcept {
        if (root_ == nullptr) [[unlikely]] {
            root_ = pool_.allocate();
            if (!root_) return {nullptr, false};
            root_->key = key;
            root_->value = PrcLevelGeneric{std::forward<Args>(args)...};
            root_->left = nullptr; root_->right = nullptr; root_->parent = nullptr; root_->height = 1;
            ++size_;
            return {root_, true};
        }

        MapNode* current = root_;
        MapNode* parent = nullptr;
        bool go_left = false;

        while (current != nullptr) {
            parent = current;
            if (comp_(key, current->key)) {
                current = current->left;
                go_left = true;
            } else if (comp_(current->key, key)) {
                current = current->right;
                go_left = false;
            } else {
                return {current, false}; 
            }
        }

        MapNode* fresh_node = pool_.allocate();
        if (!fresh_node) [[unlikely]] return {nullptr, false};
        
        fresh_node->key = key;
        fresh_node->value = PrcLevelGeneric{std::forward<Args>(args)...};
        fresh_node->left = nullptr; fresh_node->right = nullptr; fresh_node->parent = parent; fresh_node->height = 1;

        if (go_left) parent->left = fresh_node;
        else parent->right = fresh_node;

        ++size_;
        balance_upward(parent);
        return {fresh_node, true};
    }

    // Overloaded erase accepting standard iterators directly
    [[gnu::always_inline]] inline void erase(iterator it) noexcept {

template <size_t PreallocCapacity, typename Compare>
class MapIterator {
private:
    const FastNodeMap<PreallocCapacity, Compare>* container_;
    MapNode*                                      ptr_;

    // Grant friendship so the map container can peel out the internal raw node address
    friend class FastNodeMap<PreallocCapacity, Compare>;

public:
    using iterator_category = std::forward_iterator_tag;
    using value_type        = MapNode;
    using difference_type   = std::ptrdiff_t;
    using pointer           = MapNode*;
    using reference         = MapNode&;

    MapIterator(const FastNodeMap<PreallocCapacity, Compare>* container, MapNode* ptr) noexcept 
        : container_(container), ptr_(ptr) {}
    
    [[nodiscard]] inline reference operator*() const noexcept { return *ptr_; }
    [[nodiscard]] inline pointer   operator->() const noexcept { return ptr_; }
    
    inline MapIterator& operator++() noexcept {
        ptr_ = container_->next(ptr_);
        return *this;
    }
    inline MapIterator operator++(int) noexcept {
        MapIterator tmp = *this;
        ptr_ = container_->next(ptr_);
        return tmp;
    }
    [[nodiscard]] inline bool operator==(const MapIterator& o) const noexcept { return ptr_ == o.ptr_; }
    [[nodiscard]] inline bool operator!=(const MapIterator& o) const noexcept { return ptr_ != o.ptr_; }
};

template <size_t PreallocCapacity, typename Compare = std::less<uint64_t>>
class FastNodeMap {
private:
    HybridNodePool<PreallocCapacity> pool_;
    MapNode* root_{nullptr};
    size_t   size_{0};
    [[no_unique_address]] Compare comp_; 

    [[nodiscard]] [[gnu::always_inline]] inline int32_t get_height(MapNode* node) const noexcept { 
        return node ? node->height : 0; 
    }
    
    [[nodiscard]] [[gnu::always_inline]] inline int32_t get_balance(MapNode* node) const noexcept {
        if (!node) return 0;
        return get_height(node->left) - get_height(node->right);
    }
    
    [[gnu::always_inline]] inline void update_height(MapNode* node) noexcept {
        if (node) {
            node->height = 1 + std::max(get_height(node->left), get_height(node->right));
        }
    }

    MapNode* rotate_right(MapNode* y) noexcept {
        MapNode* x = y->left;
        MapNode* T2 = x->right;

        x->right = y;
        y->left = T2;

        x->parent = y->parent;
        y->parent = x;
        if (T2) T2->parent = y;

        update_height(y);
        update_height(x);
        return x;
    }

    MapNode* rotate_left(MapNode* x) noexcept {
        MapNode* y = x->right;
        MapNode* T2 = y->left;

        y->left = x;
        x->right = T2;

        y->parent = x->parent;
        x->parent = y;
        if (T2) T2->parent = x;

        update_height(x);
        update_height(y);
        return y;
    }

    MapNode* rebalance(MapNode* node) noexcept {
        update_height(node);
        int32_t balance = get_balance(node);
        if (balance > 1) {
            if (get_balance(node->left) < 0) {
                node->left = rotate_left(node->left);
            }
            return rotate_right(node);
        }
        if (balance < -1) {
            if (get_balance(node->right) < 0) {
                node->right = rotate_right(node->right);
            }
            return rotate_left(node);
        }
        return node;
    }

    void balance_upward(MapNode* node) noexcept {
        while (node != nullptr) {
            MapNode* p = node->parent;
            MapNode* new_sub_root = rebalance(node);
            
            if (p != nullptr) {
                if (p->left == node) p->left = new_sub_root;
                else p->right = new_sub_root;
                new_sub_root->parent = p;
            } else {
                root_ = new_sub_root;
                root_->parent = nullptr;
            }
            node = p; 
        }
    }

    MapNode* get_extreme_node(MapNode* node, bool find_min) const noexcept {
        MapNode* current = node;
        if (find_min) {
            while (current && current->left != nullptr) current = current->left;
        } else {
            while (current && current->right != nullptr) current = current->right;
        }
        return current;
    }


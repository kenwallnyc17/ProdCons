            if (!allocated_node) return {nullptr, false};
            m_buckets[b_idx] = allocated_node;
            m_bucket_slots.resize(m_bucket_count, 0);
            m_bucket_slots[b_idx] = slot;
        }

        Order* existing = find(key);
        if (existing) return {existing, false};


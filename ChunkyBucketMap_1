                curr->keys[slot_idx] = key;
                curr->data_slots[slot_idx] = curr_slot_idx;
                Order* order_space = m_arena.get_order_ptr(curr_slot_idx, slot_idx);
                *order_space = Order(std::forward<Args>(args)...);
                return {order_space, true};

            __m256i tomb_v  = _mm256_cmpeq_epi8(tag_lane, _mm256_set1_epi8(static_cast<char>(TAG_DELETED)));
            
            uint32_t free_mask = static_cast<uint32_t>(_mm256_movemask_epi8(_mm256_or_si256(empty_v, tomb_v))) & 0xF;



// Size: Exactly 64 bytes (1 CPU Cache Line)
struct alignas(64) MapNode {
    uint64_t        key;        
    PrcLevelGeneric value;      
    uint32_t        next_free; 
    uint32_t        is_active; 
};

constexpr uint32_t CHUNK_SHIFT = 10;
constexpr uint32_t CHUNK_SIZE  = 1U << CHUNK_SHIFT; 
constexpr uint32_t CHUNK_MASK  = CHUNK_SIZE - 1;

class DynamicNodePool {
private:
    std::vector<MapNode*> chunks_;
    uint32_t free_head_{0xFFFFFFFF};
    uint32_t total_slots_{0};

public:
    DynamicNodePool() { 
        grow_pool(); 
    }
    
    ~DynamicNodePool() noexcept {
        for (MapNode* chunk : chunks_) {
            if (chunk) {
                for (uint32_t i = 0; i < CHUNK_SIZE; ++i) chunk[i].~MapNode();
                std::free(chunk);
            }
        }
    }

    DynamicNodePool(const DynamicNodePool&) = delete;
    DynamicNodePool& operator=(const DynamicNodePool&) = delete;

    void grow_pool() {
        void* raw_mem = std::aligned_alloc(64, CHUNK_SIZE * sizeof(MapNode));
        if (!raw_mem) [[unlikely]] throw std::bad_alloc();
        
        MapNode* new_chunk = static_cast<MapNode*>(raw_mem);
        uint32_t start_global_idx = total_slots_;

        for (uint32_t i = 0; i < CHUNK_SIZE; ++i) {
            ::new (static_cast<void*>(new_chunk + i)) MapNode{0, {}, start_global_idx + i + 1, 0};
        }
        new_chunk[CHUNK_SIZE - 1].next_free = free_head_;
        free_head_ = start_global_idx;
        
        chunks_.push_back(new_chunk);
        total_slots_ += CHUNK_SIZE;
    }

    [[nodiscard]] [[gnu::always_inline]] inline size_t capacity() const noexcept { return total_slots_; }

    [[nodiscard]] [[gnu::always_inline]] inline MapNode& get(uint32_t idx) noexcept {
        return chunks_[idx >> CHUNK_SHIFT][idx & CHUNK_MASK];
    }
    [[nodiscard]] [[gnu::always_inline]] inline const MapNode& get(uint32_t idx) const noexcept {
        return chunks_[idx >> CHUNK_SHIFT][idx & CHUNK_MASK];
    }

    [[nodiscard]] [[gnu::always_inline]] inline uint32_t allocate(uint64_t key) noexcept {
        if (free_head_ >= total_slots_) [[unlikely]] {
            grow_pool();
        }
        uint32_t allocated_idx = free_head_;
        MapNode& node = get(allocated_idx);
        free_head_ = node.next_free;

        node.key = key;
        node.is_active = 1;
        return allocated_idx;
    }

    [[gnu::always_inline]] inline void deallocate(uint32_t idx) noexcept {
        if (idx >= total_slots_) [[unlikely]] return;
        MapNode& node = get(idx);
        node.is_active = 0;
        node.next_free = free_head_;
        free_head_ = idx;
    }
};

template <typename Compare> class FastNodeMap;

template <typename Compare, bool IsConst = false>
class MapIterator {
private:
    using MapType = std::conditional_t<IsConst, const FastNodeMap<Compare>, FastNodeMap<Compare>>;
    MapType* container_;
    size_t   vector_pos_; 

public:
    using iterator_category = std::forward_iterator_tag;
    using value_type        = MapNode;
    using difference_type   = std::ptrdiff_t;
    using pointer           = std::conditional_t<IsConst, const MapNode*, MapNode*>;
    using reference         = std::conditional_t<IsConst, const MapNode&, MapNode&>;

    MapIterator(MapType* container, size_t vector_pos) noexcept 
        : container_(container), vector_pos_(vector_pos) {}
    
    [[nodiscard]] inline reference operator*() const noexcept { 
        return container_->get_pool().get(container_->get_sorted_indices()[vector_pos_]); 
    }
    [[nodiscard]] inline pointer operator->() const noexcept { 
        return &container_->get_pool().get(container_->get_sorted_indices()[vector_pos_]); 
    }
    
    inline MapIterator& operator++() noexcept {
        ++vector_pos_;
        return *this;
    }
    inline MapIterator operator++(int) noexcept {
        MapIterator tmp = *this;
        ++vector_pos_;
        return tmp;
    }
    [[nodiscard]] inline bool operator==(const MapIterator& o) const noexcept { return vector_pos_ == o.vector_pos_; }
    [[nodiscard]] inline bool operator!=(const MapIterator& o) const noexcept { return vector_pos_ != o.vector_pos_; }
};

template <typename Compare = std::less<uint64_t>>
class FastNodeMap {
private:
    DynamicNodePool       pool_;
    std::vector<uint32_t> buckets_;        
    std::vector<uint32_t> sorted_indices_; 
    size_t                size_{0};
    [[no_unique_address]] Compare comp_;

    static constexpr uint32_t EMPTY_BUCKET = 0xFFFFFFFF;

    [[nodiscard]] [[gnu::always_inline]] inline uint32_t hash_key(uint64_t key) const noexcept {
        key ^= key >> 30;
        key *= 0xbf58476d1ce4e5b9ULL;
        key ^= key >> 27;
        return static_cast<uint32_t>(key);
    }

    [[gnu::noinline]] void rehash_expand() {
        size_t old_capacity = buckets_.size();
        size_t new_capacity = old_capacity * 2;
        buckets_.assign(new_capacity, EMPTY_BUCKET);

        uint32_t cap_mask = static_cast<uint32_t>(new_capacity - 1);

        for (uint32_t pool_idx : sorted_indices_) {
            const MapNode& node = pool_.get(pool_idx);
            uint32_t bucket = hash_key(node.key) & cap_mask;
            
            uint32_t current_pool_idx = pool_idx;
            uint32_t current_psl = 1;

            while (true) {
                uint32_t slot_val = buckets_[bucket];
                if (slot_val == EMPTY_BUCKET) {
                    buckets_[bucket] = current_pool_idx;
                    break;
                }
                
                uint32_t slot_hash = hash_key(pool_.get(slot_val).key);
                uint32_t slot_psl = ((bucket + new_capacity - (slot_hash & cap_mask)) & cap_mask) + 1;

                if (current_psl > slot_psl) {
                    std::swap(current_pool_idx, buckets_[bucket]);
                    current_psl = slot_psl;
                }
                bucket = (bucket + 1) & cap_mask;
                ++current_psl;
            }
        }
    }

public:
    using iterator       = MapIterator<Compare, false>;
    using const_iterator = MapIterator<Compare, true>;

    FastNodeMap() {
        buckets_.assign(1024, EMPTY_BUCKET); 
    }

    [[nodiscard]] inline iterator begin() noexcept { return iterator(this, 0); }
    [[nodiscard]] inline iterator end() noexcept   { return iterator(this, sorted_indices_.size()); }
    [[nodiscard]] inline const_iterator begin() const noexcept { return const_iterator(this, 0); }
    [[nodiscard]] inline const_iterator end() const noexcept   { return const_iterator(this, sorted_indices_.size()); }
    
    [[nodiscard]] inline DynamicNodePool& get_pool() noexcept { return pool_; }
    [[nodiscard]] inline const DynamicNodePool& get_pool() const noexcept { return pool_; }
    [[nodiscard]] inline const std::vector<uint32_t>& get_sorted_indices() const noexcept { return sorted_indices_; }

    [[nodiscard]] [[gnu::always_inline]] inline size_t size() const noexcept { return size_; }
    [[nodiscard]] [[gnu::always_inline]] inline bool empty() const noexcept { return size_ == 0; }

    void reserve(size_t expected_nodes) {
        size_t baseline_needed = (expected_nodes * 10) / 7; 
        size_t current_cap = buckets_.size();
        while (current_cap < baseline_needed) {
            current_cap *= 2;
        }
        buckets_.assign(current_cap, EMPTY_BUCKET);
        sorted_indices_.reserve(expected_nodes);
    }

    template <typename... Args>
    [[gnu::always_inline]] inline std::pair<MapNode*, bool> try_emplace(uint64_t key, Args&&... args) noexcept {
        if (size_ * 10 >= buckets_.size() * 7) [[unlikely]] {
            rehash_expand();
        }

        uint32_t cap_mask = static_cast<uint32_t>(buckets_.size() - 1);
        uint32_t bucket = hash_key(key) & cap_mask;
        uint32_t psl = 1;

        uint32_t check_bucket = bucket;
        while (true) {
            uint32_t slot_val = buckets_[check_bucket];
            if (slot_val == EMPTY_BUCKET) break;
            
            MapNode& node = pool_.get(slot_val);
            uint32_t slot_hash = hash_key(node.key);
            uint32_t slot_psl = ((check_bucket + buckets_.size() - (slot_hash & cap_mask)) & cap_mask) + 1;

            if (psl > slot_psl) break;
            if (node.key == key) return {&node, false};

            check_bucket = (check_bucket + 1) & cap_mask;
            ++psl;
        }

        uint32_t pool_idx = pool_.allocate(key);
        MapNode& fresh_node = pool_.get(pool_idx);
        fresh_node.value = PrcLevelGeneric{std::forward<Args>(args)...};

        uint32_t current_pool_idx = pool_idx;
        uint32_t current_psl = 1;
        MapNode* first_inserted_ptr = &fresh_node;

        while (true) {
            uint32_t slot_val = buckets_[bucket];

            if (slot_val == EMPTY_BUCKET) {
                buckets_[bucket] = current_pool_idx;
                break;
            }

            MapNode& slot_node = pool_.get(slot_val);
            uint32_t slot_hash = hash_key(slot_node.key);
            uint32_t slot_psl = ((bucket + buckets_.size() - (slot_hash & cap_mask)) & cap_mask) + 1;

            if (current_psl > slot_psl) {
                std::swap(current_pool_idx, buckets_[bucket]);
                current_psl = slot_psl;
            }

            bucket = (bucket + 1) & cap_mask;
            ++current_psl;
        }

        auto it = std::lower_bound(sorted_indices_.begin(), sorted_indices_.end(), pool_idx, [this](uint32_t a, uint32_t b) {
            return comp_(pool_.get(a).key, pool_.get(b).key);
        });
        sorted_indices_.insert(it, pool_idx);
        ++size_;

        return {first_inserted_ptr, true};
    }

    [[gnu::always_inline]] void erase(MapNode* node_ptr) noexcept {
        if (!node_ptr || node_ptr->is_active == 0) return;
        
        uint32_t cap_mask = static_cast<uint32_t>(buckets_.size() - 1);
        uint32_t bucket = hash_key(node_ptr->key) & cap_mask;
        
        while (buckets_[bucket] != EMPTY_BUCKET) {
            if (&pool_.get(buckets_[bucket]) == node_ptr) break;
            bucket = (bucket + 1) & cap_mask;
        }
        if (buckets_[bucket] == EMPTY_BUCKET) return;

        uint32_t target_pool_idx = buckets_[bucket];

        auto s_it = std::find(sorted_indices_.begin(), sorted_indices_.end(), target_pool_idx);
        if (s_it != sorted_indices_.end()) sorted_indices_.erase(s_it);

        while (true) {
            uint32_t next_bucket = (bucket + 1) & cap_mask;
            uint32_t next_val = buckets_[next_bucket];

            if (next_val == EMPTY_BUCKET) {
                buckets_[bucket] = EMPTY_BUCKET;
                break;
            }

            uint32_t next_hash = hash_key(pool_.get(next_val).key);
            uint32_t next_psl = ((next_bucket + buckets_.size() - (next_hash & cap_mask)) & cap_mask) + 1;

            if (next_psl <= 1) {
                buckets_[bucket] = EMPTY_BUCKET;
                break;
            }

            buckets_[bucket] = next_val;
            bucket = next_bucket;
        }

        pool_.deallocate(target_pool_idx);
        --size_;
    }

    [[nodiscard]] [[gnu::always_inline]] inline MapNode* find(uint64_t key) noexcept {
        uint32_t cap_mask = static_cast<uint32_t>(buckets_.size() - 1);
        uint32_t bucket = hash_key(key) & cap_mask;
        uint32_t psl = 1;

        while (true) {
            uint32_t slot_val = buckets_[bucket];
            if (slot_val == EMPTY_BUCKET) return nullptr;
            
            MapNode& node = pool_.get(slot_val);
            uint32_t slot_hash = hash_key(node.key);
            uint32_t slot_psl = ((bucket + buckets_.size() - (slot_hash & cap_mask)) & cap_mask) + 1;

            if (psl > slot_psl) return nullptr;
            if (node.key == key) return &node;

            bucket = (bucket + 1) & cap_mask;
            ++psl;
        }
    }

    [[gnu::always_inline]] inline size_t extract_volumes_simd(uint32_t* __restrict__ destination_array) const noexcept {
        uint32_t* aligned_dest = static_cast<uint32_t*>(__builtin_assume_aligned(destination_array, 64));
        size_t count = 0;
        for (uint32_t idx : sorted_indices_) {
            aligned_dest[count++] = pool_.get(idx).value.agg_sz;
        }
        return count; 
    }
};
